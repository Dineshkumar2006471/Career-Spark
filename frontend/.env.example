# Supabase project URL used by the browser client for auth and RLS-protected data.
VITE_SUPABASE_URL=your_supabase_project_url

# Supabase publishable/anon key used by the browser client; never use the service role key here.
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# FastAPI backend URL used by frontend services in development and deployment.
VITE_BACKEND_URL=http://localhost:8000

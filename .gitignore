# Local dependency folders are generated by package managers and should not be committed.
node_modules/

# Python virtual environments and caches are local machine artifacts.
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/

# Real environment files contain API keys and deployment secrets.
.env
.env.*
!.env.example

# Build outputs are generated by Vite or deployment providers.
dist/
build/

# Local editor and operating-system files are not project source.
.vscode/
.idea/
.DS_Store
Thumbs.db

# Runtime logs are generated during local development.
*.log

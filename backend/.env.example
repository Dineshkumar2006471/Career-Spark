# NVIDIA NIM API key used by backend AI services for Llama 3.1 roadmap and chatbot calls.
NVIDIA_API_KEY=your_nvidia_nim_api_key

# Supabase project URL used by trusted backend services.
VERTEX_PROJECT_ID=smartbharat-501705
VERTEX_LOCATION=us-central1
SUPABASE_URL=your_supabase_project_url

# Supabase service role key used only on the backend for privileged server-side operations.
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Adzuna application ID used with the Adzuna jobs API.
ADZUNA_APP_ID=your_adzuna_app_id

# Adzuna API key used with the Adzuna jobs API.
ADZUNA_APP_KEY=your_adzuna_api_key

# Optional GitHub token used only to raise public GitHub API rate limits.
GITHUB_TOKEN=optional_for_higher_rate_limits

# Browser origins allowed by FastAPI CORS in local or deployed environments.
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
